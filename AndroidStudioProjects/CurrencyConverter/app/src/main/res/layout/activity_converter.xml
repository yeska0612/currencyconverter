<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgFlagTop"
            android:layout_width="180dp"
            android:layout_height="110dp"
            android:layout_marginTop="40dp"
            android:scaleType="fitCenter"
            android:src="@drawable/flag_eur" />

        <Spinner
            android:id="@+id/spinnerCurrency"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvTopCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="EUR"
            android:textColor="@color/black_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:hint="1"
            android:inputType="numberDecimal"
            android:textColor="@color/black_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAmountHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Хөрвүүлэх дүн"
            android:textColor="@color/gray_text"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSwap"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Солих"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnConvert"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/blue_light"
            android:text="Хөрвүүлэх"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="220dp"
            android:layout_height="1dp"
            android:layout_marginTop="50dp"
            android:background="@color/gray_line" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="4,032.00"
            android:textColor="@color/black_text"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBottomCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="MNT"
            android:textColor="@color/black_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgFlagBottom"
            android:layout_width="180dp"
            android:layout_height="110dp"
            android:layout_marginTop="18dp"
            android:scaleType="fitCenter"
            android:src="@drawable/flag_mnt" />

    </LinearLayout>
</ScrollView>